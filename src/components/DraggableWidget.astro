---
// DraggableWidget.astro - 修复变形，正确处理 cover 模式
interface Props {
  id: string;
  title?: string;
  initialX?: number;
  initialY?: number;
  initialWidth?: number;
  initialHeight?: number;
  minWidth?: number;
  minHeight?: number;
  magnifierScale?: number;
  animate?: boolean;
  transparent?: boolean;
  noResize?: boolean;
  index?: number;
}

const {
  id,
  title = "窗口",
  initialX = 100,
  initialY = 100,
  initialWidth = 300,
  initialHeight = 200,
  minWidth = 100,
  minHeight = 80,
  magnifierScale = 1,
  transparent = false,
  noResize = false,
  animate = true,
  index = 0,
} = Astro.props;

const animationDelay = animate ? index * 200 : 0;
---

<div
  class:list={[
    "draggable-widget",
    { "is-transparent": transparent, "pop-in": animate },
  ]}
  id={id}
  data-magnifier-scale={magnifierScale}
  data-min-width={minWidth}
  data-min-height={minHeight}
  data-no-resize={noResize}
  style={`
    left: ${initialX}px;
    top: ${initialY}px;
    width: ${initialWidth}px;
    height: ${initialHeight}px;
    animation-delay: ${animationDelay}ms;
  `}
>
  <div class="widget-header" data-header>
    <span class="widget-title">{title}</span>
    <button class="widget-close" data-close aria-label="关闭">×</button>
  </div>

  <div class="widget-content" data-content>
    <div class="widget-slot-content">
      <slot />
    </div>
  </div>

  <div class="magnifier-layer" data-magnifier></div>

  {
    !noResize && (
      <div class="resize-handlers">
        <div class="resize-handle top" data-dir="top" />
        <div class="resize-handle right" data-dir="right" />
        <div class="resize-handle bottom" data-dir="bottom" />
        <div class="resize-handle left" data-dir="left" />
        <div class="resize-handle top-left" data-dir="top-left" />
        <div class="resize-handle top-right" data-dir="top-right" />
        <div class="resize-handle bottom-left" data-dir="bottom-left" />
        <div class="resize-handle bottom-right" data-dir="bottom-right" />
      </div>
    )
  }
</div>

<script is:inline>
  (function () {
    "use strict";

    if (window.__widgetManagerReady) return;
    window.__widgetManagerReady = true;

    const widgets = new Map();
    let zIndexCounter = 50;
    let activeWidget = null;
    let dragState = null;

    function bringToFront(widget) {
      zIndexCounter++;
      // 添加上限，确保不超过菜单栏（假设菜单栏是 1000）
      const MAX_Z_INDEX = 999;
      const newZ = Math.min(zIndexCounter, MAX_Z_INDEX);

      widget.style.zIndex = newZ;
      const data = widgets.get(widget.id);
      if (data) data.zIndex = newZ;
    }

    function init() {
      document.querySelectorAll(".draggable-widget").forEach(registerWidget);

      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node.nodeType === 1) {
              if (node.classList.contains("draggable-widget")) {
                registerWidget(node);
              }
              node
                .querySelectorAll?.(".draggable-widget")
                .forEach(registerWidget);
            }
          });
        });
      });
      observer.observe(document.body, { childList: true, subtree: true });
    }

    function registerWidget(widget) {
      if (widgets.has(widget.id)) return;

      const header = widget.querySelector("[data-header]");
      const closeBtn = widget.querySelector("[data-close]");
      const magnifier = widget.querySelector("[data-magnifier]");
      const slotContent = widget.querySelector(".widget-slot-content");

      let sourceImg = null;
      if (slotContent) {
        const img = slotContent.querySelector("img");
        if (img && img.src) {
          sourceImg = img;
          if (!img.complete) {
            img.addEventListener("load", () => updateMagnifier(widget));
          }
        }
      }

      if (closeBtn) {
        closeBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          widget.classList.add("closing");
          setTimeout(() => {
            widget.remove();
            widgets.delete(widget.id);
            updateAllMagnifiers();
          }, 200);
        });
      }

      if (header) {
        header.addEventListener("mousedown", (e) => {
          if (e.target.closest("[data-close]")) return;
          startDrag(e, widget);
        });
      }

      widget.querySelectorAll(".resize-handle").forEach((handle) => {
        handle.addEventListener("mousedown", (e) => {
          e.stopPropagation();
          startResize(e, widget, handle.dataset.dir);
        });
      });

      widget.addEventListener("mousedown", () => {
        bringToFront(widget);
        updateAllMagnifiers();
      });

      widgets.set(widget.id, {
        element: widget,
        sourceImg: sourceImg,
        magnifierScale: parseFloat(widget.dataset.magnifierScale) || 1.2,
        minWidth: parseFloat(widget.dataset.minWidth) || 100,
        minHeight: parseFloat(widget.dataset.minHeight) || 80,
        magnifierEl: magnifier,
        zIndex: 100,
      });

      bringToFront(widget);
      updateMagnifier(widget);

      if (widget.classList.contains("pop-in")) {
        const delay = parseFloat(getComputedStyle(widget).animationDelay) || 0;
        setTimeout(
          () => {
            widget.classList.remove("pop-in");
            widget.style.willChange = "auto";
          },
          600 + delay * 1000,
        );
      }
    }

    function startDrag(e, widget) {
      activeWidget = widget;
      dragState = {
        type: "drag",
        startX: e.clientX,
        startY: e.clientY,
        startLeft: widget.offsetLeft,
        startTop: widget.offsetTop,
      };

      bringToFront(widget);
      widget.style.transition = "none";
      document.body.style.cursor = "grabbing";
      e.preventDefault();
    }

    function startResize(e, widget, dir) {
      activeWidget = widget;
      dragState = {
        type: "resize",
        dir: dir,
        startX: e.clientX,
        startY: e.clientY,
        startLeft: widget.offsetLeft,
        startTop: widget.offsetTop,
        startWidth: widget.offsetWidth,
        startHeight: widget.offsetHeight,
      };

      bringToFront(widget);
      widget.style.transition = "none";

      const cursors = {
        top: "n-resize",
        bottom: "s-resize",
        left: "w-resize",
        right: "e-resize",
        "top-left": "nw-resize",
        "top-right": "ne-resize",
        "bottom-left": "sw-resize",
        "bottom-right": "se-resize",
      };
      document.body.style.cursor = cursors[dir] || "default";
      e.preventDefault();
    }

    function onMouseMove(e) {
      if (!activeWidget || !dragState) return;

      if (dragState.type === "drag") {
        const dx = e.clientX - dragState.startX;
        const dy = e.clientY - dragState.startY;
        activeWidget.style.left = dragState.startLeft + dx + "px";
        activeWidget.style.top = dragState.startTop + dy + "px";
        updateAllMagnifiers();
      } else if (dragState.type === "resize") {
        const dx = e.clientX - dragState.startX;
        const dy = e.clientY - dragState.startY;
        const data = widgets.get(activeWidget.id);

        let newLeft = dragState.startLeft;
        let newTop = dragState.startTop;
        let newWidth = dragState.startWidth;
        let newHeight = dragState.startHeight;

        if (dragState.dir.includes("right")) {
          newWidth = Math.max(data.minWidth, dragState.startWidth + dx);
        }
        if (dragState.dir.includes("left")) {
          newWidth = Math.max(data.minWidth, dragState.startWidth - dx);
          newLeft = dragState.startLeft + dx;
        }
        if (dragState.dir.includes("bottom")) {
          newHeight = Math.max(data.minHeight, dragState.startHeight + dy);
        }
        if (dragState.dir.includes("top")) {
          newHeight = Math.max(data.minHeight, dragState.startHeight - dy);
          newTop = dragState.startTop + dy;
        }

        activeWidget.style.left = newLeft + "px";
        activeWidget.style.top = newTop + "px";
        activeWidget.style.width = newWidth + "px";
        activeWidget.style.height = newHeight + "px";
        updateAllMagnifiers();
      }
    }

    function onMouseUp() {
      if (!activeWidget) return;
      activeWidget.style.transition = "";
      document.body.style.cursor = "";
      activeWidget = null;
      dragState = null;
      updateAllMagnifiers();
    }

    function bringToFront(widget) {
      zIndexCounter++;
      widget.style.zIndex = zIndexCounter;
      const data = widgets.get(widget.id);
      if (data) data.zIndex = zIndexCounter;
    }

    function updateAllMagnifiers() {
      widgets.forEach((data) => {
        updateMagnifier(data.element);
      });
    }

    // 核心：正确处理 object-fit: cover 的图片，保持比例不形变
    function updateMagnifier(widget) {
      const data = widgets.get(widget.id);
      if (!data || !data.magnifierEl) return;

      const magnifier = data.magnifierEl;
      const scale = data.magnifierScale;

      const widgetRect = widget.getBoundingClientRect();
      const headerHeight = 32;

      const contentRect = {
        left: widgetRect.left,
        top: widgetRect.top + headerHeight,
        right: widgetRect.right,
        bottom: widgetRect.bottom,
      };

      let bestSource = null;
      let bestZ = -1;

      // 检查Hero Character
      const heroSection = document.getElementById("hero-section");
      if (heroSection) {
        const heroImg = heroSection.querySelector(".hero-character img");
        if (heroImg) {
          const heroRect = heroImg.getBoundingClientRect();
          const overlap = getOverlapRect(contentRect, heroRect);
          if (overlap) {
            bestSource = { img: heroImg, overlap, zIndex: 1 };
            bestZ = 1;
          }
        }
      }

      // 检查其他widget
      widgets.forEach((otherData, otherId) => {
        if (otherId === widget.id) return;
        if (!otherData.sourceImg) return;

        const imgRect = otherData.sourceImg.getBoundingClientRect();
        const overlap = getOverlapRect(contentRect, imgRect);
        if (overlap && otherData.zIndex > bestZ) {
          bestSource = {
            img: otherData.sourceImg,
            overlap,
            zIndex: otherData.zIndex,
          };
          bestZ = otherData.zIndex;
        }
      });

      if (!bestSource) {
        magnifier.style.display = "none";
        return;
      }

      magnifier.style.display = "block";

      const img = bestSource.img;
      const naturalWidth = img.naturalWidth || img.width || 100;
      const naturalHeight = img.naturalHeight || img.height || 100;
      const containerRect = img.getBoundingClientRect(); // 容器尺寸

      // 计算 object-fit: cover 下图片的实际渲染尺寸和偏移
      const containerRatio = containerRect.width / containerRect.height;
      const imageRatio = naturalWidth / naturalHeight;

      let renderedWidth, renderedHeight, offsetX, offsetY;

      if (containerRatio > imageRatio) {
        // 容器更宽，图片按高度比例填满，左右被裁剪
        renderedHeight = containerRect.height;
        renderedWidth = renderedHeight * imageRatio;
        offsetX = (containerRect.width - renderedWidth) / 2;
        offsetY = 0;
      } else {
        // 容器更高，图片按宽度比例填满，上下被裁剪
        renderedWidth = containerRect.width;
        renderedHeight = renderedWidth / imageRatio;
        offsetX = 0;
        offsetY = (containerRect.height - renderedHeight) / 2;
      }

      // 关键修复：使用 natural 尺寸计算背景图大小（保持原始比例，防止变形）
      const bgWidth = naturalWidth * scale;
      const bgHeight = naturalHeight * scale;

      // 计算重叠区域在"渲染后图片"中的位置
      const overlapLeftInRendered =
        bestSource.overlap.left - (containerRect.left + offsetX);
      const overlapTopInRendered =
        bestSource.overlap.top - (containerRect.top + offsetY);

      // 转换为 natural 坐标系（因为 background-size 是基于 natural 的）
      const ratioX = naturalWidth / renderedWidth;
      const ratioY = naturalHeight / renderedHeight;

      const bgX = -(overlapLeftInRendered * ratioX * scale);
      const bgY = -(overlapTopInRendered * ratioY * scale);

      // 相对于 widget 的位置
      const relLeft = bestSource.overlap.left - widgetRect.left;
      const relTop = bestSource.overlap.top - widgetRect.top;
      const relWidth = bestSource.overlap.right - bestSource.overlap.left;
      const relHeight = bestSource.overlap.bottom - bestSource.overlap.top;

      magnifier.style.left = relLeft + "px";
      magnifier.style.top = relTop + "px";
      magnifier.style.width = relWidth + "px";
      magnifier.style.height = relHeight + "px";

      magnifier.style.backgroundImage = `url(${img.src})`;
      magnifier.style.backgroundSize = `${bgWidth}px ${bgHeight}px`;
      magnifier.style.backgroundPosition = `${bgX}px ${bgY}px`;
    }

    function getOverlapRect(a, b) {
      const left = Math.max(a.left, b.left);
      const top = Math.max(a.top, b.top);
      const right = Math.min(a.right, b.right);
      const bottom = Math.min(a.bottom, b.bottom);
      if (right > left && bottom > top) {
        return { left, top, right, bottom };
      }
      return null;
    }

    document.addEventListener("mousemove", onMouseMove);
    document.addEventListener("mouseup", onMouseUp);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>

<style>
  .draggable-widget {
    position: absolute;
    background: white;
    border: 1px solid #ccc;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    overflow: visible;
    user-select: none;
    z-index: 100;
    opacity: 0;
    transform: translate3d(0, 20px, 0) scale(0.92);
    will-change: transform, opacity;
  }

  @keyframes dwPopIn {
    0% {
      opacity: 0;
      transform: translate3d(0, 20px, 0) scale(0.92);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  .draggable-widget.pop-in {
    animation: dwPopIn 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .draggable-widget:not(.pop-in) {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    will-change: auto;
  }

  .draggable-widget.closing {
    animation: dwPopOut 200ms ease forwards;
  }

  @keyframes dwPopOut {
    to {
      opacity: 0;
      transform: scale(0.9);
    }
  }

  .draggable-widget.is-transparent {
    background: transparent;
    border: none;
    box-shadow: none;
  }

  .draggable-widget.is-transparent .widget-header {
    background: rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
  }

  .widget-header {
    height: 32px;
    background: linear-gradient(180deg, #f5f5f5 0%, #e8e8e8 100%);
    border-bottom: 1px solid #ccc;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 10px;
    cursor: grab;
    touch-action: none;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    border-radius: 8px 8px 0 0;
  }

  .widget-header:active {
    cursor: grabbing;
  }

  .widget-title {
    font-size: 13px;
    color: #333;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    pointer-events: none;
  }

  .widget-close {
    width: 20px;
    height: 20px;
    border: none;
    background: transparent;
    color: #666;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .widget-close:hover {
    background: #e81123;
    color: white;
  }

  .widget-content {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: #f9f9f9;
    min-height: 0;
    border-radius: 0 0 8px 8px;
  }

  .widget-slot-content {
    position: absolute;
    inset: 0;
  }

  .widget-slot-content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .magnifier-layer {
    position: absolute;
    pointer-events: none;
    z-index: 5;
    background-repeat: no-repeat;
    display: none;
  }

  .resize-handlers {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
  }

  .resize-handle {
    position: absolute;
    pointer-events: auto;
    background: transparent;
  }

  .resize-handle.top {
    top: -3px;
    left: 8px;
    right: 8px;
    height: 6px;
    cursor: n-resize;
  }
  .resize-handle.bottom {
    bottom: -3px;
    left: 8px;
    right: 8px;
    height: 6px;
    cursor: s-resize;
  }
  .resize-handle.left {
    left: -3px;
    top: 8px;
    bottom: 8px;
    width: 6px;
    cursor: w-resize;
  }
  .resize-handle.right {
    right: -3px;
    top: 8px;
    bottom: 8px;
    width: 6px;
    cursor: e-resize;
  }
  .resize-handle.top-left {
    top: -3px;
    left: -3px;
    width: 12px;
    height: 12px;
    cursor: nw-resize;
  }
  .resize-handle.top-right {
    top: -3px;
    right: -3px;
    width: 12px;
    height: 12px;
    cursor: ne-resize;
  }
  .resize-handle.bottom-left {
    bottom: -3px;
    left: -3px;
    width: 12px;
    height: 12px;
    cursor: sw-resize;
  }
  .resize-handle.bottom-right {
    bottom: -3px;
    right: -3px;
    width: 12px;
    height: 12px;
    cursor: se-resize;
  }
</style>
