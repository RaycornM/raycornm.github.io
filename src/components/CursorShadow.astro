---
// 带阴影效果的自定义光标组件
// 使用方法: 在布局文件中引入 <CursorShadow />
// 注意：这会隐藏默认光标，使用自定义元素替代
---

<style is:global>
  /* 隐藏默认光标 */
  body.custom-cursor-shadow,
  body.custom-cursor-shadow *,
  body.custom-cursor-shadow a,
  body.custom-cursor-shadow button {
    cursor: none !important;
  }
  
  /* 自定义光标元素 */
  #cursor-shadow {
    position: fixed;
    width: 32px;
    height: 32px;
    pointer-events: none;
    z-index: 99999;
    /* 确保背景透明 */
    background: transparent !important;
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
    /* 平滑过渡 - 只对 transform 生效，不影响初始位置 */
    transition: transform 0.03s ease-out;
    image-rendering: pixelated;
    /* 初始完全隐藏 */
    opacity: 0 !important;
    visibility: hidden;
    /* 确保图片透明背景正常显示 */
    mix-blend-mode: normal;
  }
  
  /* 激活状态 */
  #cursor-shadow.active {
    opacity: 1 !important;
    visibility: visible;
  }
  
  /* 光标激活状态 */
  #cursor-shadow.active {
    opacity: 1;
  }
  
  /* 点击时的缩小效果 */
  #cursor-shadow.clicking {
    transform: scale(0.92);
  }
  
  /* 确保光标不响应任何事件 */
  #cursor-shadow, #cursor-shadow * {
    pointer-events: none !important;
    user-select: none !important;
  }
</style>

<script>
  (function() {
    // 检查是否是触摸设备（触摸设备不启用）
    const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;
    if (isTouchDevice) {
      console.log('[CursorShadow] 触摸设备，跳过自定义光标');
      return;
    }
    
    // 检查是否支持 CSS 滤镜
    const testEl = document.createElement('div');
    if (!('filter' in testEl.style)) {
      console.log('[CursorShadow] 浏览器不支持滤镜，跳过自定义光标');
      return;
    }
    
    // 创建光标图片元素
    const cursor = document.createElement('img');
    cursor.id = 'cursor-shadow';
    cursor.src = '/cursors/Pointer.png'; // 默认指针
    cursor.alt = '';
    cursor.draggable = false;
    // 初始位置设为屏幕外，避免在左上角显示
    cursor.style.left = '-9999px';
    cursor.style.top = '-9999px';
    cursor.style.opacity = '0'; // 初始不可见
    document.body.appendChild(cursor);
    
    // 启用自定义光标
    document.body.classList.add('custom-cursor-shadow');
    
    // 鼠标位置
    let mouseX = 0, mouseY = 0;
    let cursorX = 0, cursorY = 0;
    let hasMouseMoved = false;
    
    // 监听鼠标移动
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      
      // 第一次移动时显示光标
      if (!hasMouseMoved) {
        hasMouseMoved = true;
        cursor.classList.add('active');
        cursor.style.opacity = '1';
        // 立即设置位置，避免从左上角飘过来
        cursorX = mouseX;
        cursorY = mouseY;
        cursor.style.left = cursorX + 'px';
        cursor.style.top = cursorY + 'px';
      }
    }, { passive: true });
    
    // 平滑跟随动画
    let animationId = null;
    function animate() {
      // 线性插值让跟随更平滑
      const dx = mouseX - cursorX;
      const dy = mouseY - cursorY;
      
      cursorX += dx * 0.25;
      cursorY += dy * 0.25;
      
      cursor.style.left = cursorX + 'px';
      cursor.style.top = cursorY + 'px';
      
      animationId = requestAnimationFrame(animate);
    }
    animate();
    
    // 光标状态映射
    const cursorStates = {
      'default': '/cursors/Pointer.png',
      'pointer': '/cursors/Link.png',
      'text': '/cursors/Text.png',
      'wait': '/cursors/Busy.png',
      'help': '/cursors/Help.png',
      'move': '/cursors/Move.png',
      'crosshair': '/cursors/Cross.png',
      'zoom-in': '/cursors/Zoom-in.png',
      'zoom-out': '/cursors/Zoom-out.png',
      'grab': '/cursors/Pan.png',
      'grabbing': '/cursors/Grabbing.png',
      'not-allowed': '/cursors/Unavailable.png',
      'ew-resize': '/cursors/Horz.png',
      'ns-resize': '/cursors/Vert.png',
      'nwse-resize': '/cursors/Dgn1.png',
      'nesw-resize': '/cursors/Dgn2.png'
    };
    
    // 当前状态
    let currentState = 'default';
    
    // 检测光标状态
    function detectCursorState() {
      const element = document.elementFromPoint(mouseX, mouseY);
      if (!element) return 'default';
      
      const tagName = element.tagName.toLowerCase();
      
      // 1. 首先检查特殊类（优先级最高）
      if (element.classList.contains('cursor-busy')) return 'wait';
      if (element.classList.contains('cursor-help')) return 'help';
      if (element.classList.contains('cursor-move')) return 'move';
      if (element.classList.contains('cursor-crosshair')) return 'crosshair';
      if (element.classList.contains('cursor-zoom-in')) return 'zoom-in';
      if (element.classList.contains('cursor-zoom-out')) return 'zoom-out';
      if (element.classList.contains('cursor-grab')) return 'grab';
      if (element.classList.contains('cursor-grabbing')) return 'grabbing';
      if (element.classList.contains('cursor-resize-h')) return 'ew-resize';
      if (element.classList.contains('cursor-resize-v')) return 'ns-resize';
      if (element.classList.contains('cursor-resize-d1')) return 'nwse-resize';
      if (element.classList.contains('cursor-resize-d2')) return 'nesw-resize';
      
      // 2. 检查禁用状态
      if (element.disabled || element.classList.contains('disabled')) {
        return 'not-allowed';
      }
      
      // 3. 检查链接和按钮（优先级高于 draggable）
      // 直接是链接或按钮
      if (tagName === 'a' || tagName === 'button') {
        return 'pointer';
      }
      
      // 有 button 角色的元素
      if (element.getAttribute('role') === 'button') {
        return 'pointer';
      }
      
      // 有 onclick 事件的元素（但不是拖拽句柄）
      if (element.onclick && !element.draggable) {
        return 'pointer';
      }
      
      // 在链接或按钮内部
      const closestLink = element.closest('a');
      const closestButton = element.closest('button');
      if (closestLink || closestButton) {
        return 'pointer';
      }
      
      // 4. 检查可编辑文本（输入框）
      if (tagName === 'input' || tagName === 'textarea') {
        const inputType = element.type;
        if (!inputType || ['text', 'email', 'password', 'search', 'url', 'number', 'tel'].includes(inputType)) {
          return 'text';
        }
      }
      
      // 5. 检查 contenteditable
      if (element.isContentEditable || element.closest('[contenteditable="true"]')) {
        return 'text';
      }
      
      // 6. 检查拖拽（在按钮检查之后）
      if (element.draggable) {
        return 'move';
      }
      
      // 7. 检查计算样式
      const computedStyle = window.getComputedStyle(element);
      const nativeCursor = computedStyle.cursor;
      
      if (nativeCursor === 'pointer') return 'pointer';
      if (nativeCursor === 'text') return 'text';
      if (nativeCursor === 'wait') return 'wait';
      if (nativeCursor === 'help') return 'help';
      if (nativeCursor === 'move') return 'move';
      if (nativeCursor === 'crosshair') return 'crosshair';
      if (nativeCursor === 'zoom-in') return 'zoom-in';
      if (nativeCursor === 'zoom-out') return 'zoom-out';
      if (nativeCursor === 'grab') return 'grab';
      if (nativeCursor === 'grabbing') return 'grabbing';
      if (nativeCursor === 'not-allowed') return 'not-allowed';
      if (nativeCursor === 'ew-resize') return 'ew-resize';
      if (nativeCursor === 'ns-resize') return 'ns-resize';
      if (nativeCursor === 'nwse-resize') return 'nwse-resize';
      if (nativeCursor === 'nesw-resize') return 'nesw-resize';
      
      // 8. 检查是否是文本内容（p, span, div 等包含文字的元素）
      // 排除特定元素（如图片、视频、canvas 等）
      const nonTextElements = ['img', 'video', 'canvas', 'svg', 'iframe', 'object', 'embed', 'audio'];
      if (nonTextElements.includes(tagName)) {
        return 'default';
      }
      
      // 如果是纯文本节点或包含文本的元素，显示 text 光标
      // 检查元素是否有文本内容（排除空白）
      const textContent = element.textContent || '';
      const hasText = textContent.trim().length > 0;
      
      // 如果是常见的文本标签，或者有大段文本内容
      const textTags = ['p', 'span', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'article', 'section', 'main', 'div', 'li', 'td', 'th', 'label', 'figcaption', 'blockquote', 'pre', 'code'];
      
      if (hasText && (textTags.includes(tagName) || element.childNodes.length > 0)) {
        // 进一步检查是否是真正的文本内容，而不是嵌套的其他元素
        // 如果子元素都是内联文本节点或文本，则认为是文本区域
        const hasChildTextNodes = Array.from(element.childNodes).some(node => 
          node.nodeType === Node.TEXT_NODE && node.textContent.trim().length > 0
        );
        
        if (hasChildTextNodes) {
          return 'text';
        }
      }
      
      return 'default';
    }
    
    // 更新光标图片
    function updateCursor() {
      const newState = detectCursorState();
      
      if (newState !== currentState) {
        currentState = newState;
        const newSrc = cursorStates[newState] || cursorStates['default'];
        
        // 预加载图片后切换
        const img = new Image();
        img.onload = () => {
          cursor.src = newSrc;
        };
        img.onerror = () => {
          // 加载失败使用默认
          cursor.src = cursorStates['default'];
        };
        img.src = newSrc;
        

      }
    }
    
    // 节流检测（每 50ms 检测一次）
    let lastCheck = 0;
    function throttledUpdate() {
      const now = Date.now();
      if (now - lastCheck > 50) {
        updateCursor();
        lastCheck = now;
      }
      requestAnimationFrame(throttledUpdate);
    }
    throttledUpdate();
    
    // 点击效果
    document.addEventListener('mousedown', () => {
      cursor.classList.add('clicking');
    });
    
    document.addEventListener('mouseup', () => {
      cursor.classList.remove('clicking');
    });
    
    // 鼠标离开窗口时隐藏
    document.addEventListener('mouseleave', () => {
      cursor.style.opacity = '0';
    });
    
    document.addEventListener('mouseenter', () => {
      if (hasMouseMoved) {
        cursor.style.opacity = '1';
      }
    });
    
    // 清理函数（页面卸载时）
    window.addEventListener('beforeunload', () => {
      if (animationId) {
        cancelAnimationFrame(animationId);
      }
    });
    
    console.log('[CursorShadow] 带阴影的自定义光标已启用');
  })();
</script>
