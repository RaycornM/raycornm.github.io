---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<!-- Mobile menu toggle -->
		<button id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
			<span class="hamburger" aria-hidden="true"></span>
		</button>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/photo">Album</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://space.bilibili.com/4572890?spm_id_from=333.1007.0.0" target="_blank">
    			<span class="sr-only">Follow me on Bilibili</span>
    			<img 
        			src="https://registry.npmmirror.com/@lobehub/icons-static-png/latest/files/light/bilibili.png" 
        			width="32" 
        			height="32" 
        			aria-hidden="true" 
        			alt="Bilibili icon"
    			/>
			</a>
			<a href="https://www.instagram.com/denkyraymond/" target="_blank">
    		<span class="sr-only">Follow me on Instagram</span>
    		<img 
        		src="https://www.svgrepo.com/show/83715/instagram-logo.svg" 
        		width="32" 
        		height="32" 
        		aria-hidden="true" 
        		alt="Instagram icon"
    		/>
		</a>
		<a href="https://github.com/RaycornM" target="_blank">
			<span class="sr-only">Go to my GitHub repo</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg, rgba(255,255,255,0.95));
		color: var(--header-text, var(--black));
		box-shadow: var(--header-shadow, 0 2px 8px rgba(var(--black), 5%));
		position: sticky; /* keep nav visible */
		top: 0;
		left: 0;
		right: 0;
		z-index: 60; /* sit above page content */
		-webkit-backdrop-filter: var(--header-backdrop, none);
		backdrop-filter: var(--header-backdrop, none);
		transition: background 0.18s ease, color 0.12s ease, box-shadow 0.18s ease;
	}

	h2 {
 		margin: 0;
 		font-size: 1em;
 	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--header-text, var(--black)); /* ensure site title link follows header text color */
	}

	/* Stronger rule for the site title to override other global styles */
	header h2 a {
		color: var(--header-text, var(--black)) !important;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	nav a {
		padding: 1em 0.5em;
		color: inherit;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	.social-links,
	.social-links a {
		display: flex;
	}

	/* allow controlling raster social icons via CSS var */
	.social-links img {
		width: 32px;
		height: 32px;
		object-fit: contain;
		filter: var(--social-icon-filter, none);
		transition: filter 0.12s ease, opacity 0.12s ease;
	}

/* Mobile nav toggle */
.nav-toggle {
	display: none;
	background: transparent;
	border: none;
	width: 44px;
	height: 44px;
	align-items: center;
	justify-content: center;
	cursor: pointer;
}
	.nav-toggle .hamburger {
		width: 22px;
		height: 2px;
		background: var(--hamburger-color, currentColor);
		display: inline-block;
		position: relative;
	}
	.nav-toggle .hamburger::before,
	.nav-toggle .hamburger::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		height: 2px;
		background: var(--hamburger-color, currentColor);
	}
	.nav-toggle .hamburger::before { top: -7px; }
	.nav-toggle .hamburger::after { top: 7px; }

@media (max-width: 720px) {
	.nav-toggle { display: inline-flex; }
	.internal-links { display: none; }
	header nav.menu-open .internal-links {
		display: flex;
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		background: var(--header-bg, rgba(255,255,255,0.98));
		flex-direction: column;
		gap: 0;
		padding: 0.5rem 1rem 1rem 1rem;
		box-shadow: 0 6px 24px rgba(0,0,0,0.08);
		z-index: 70;
	}
	header nav.menu-open .internal-links a { padding: 0.75rem 0; }
	.social-links { display: none; }
}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
<script is:inline>
(() => {
	try {
		const toggle = document.getElementById('nav-toggle');
		const nav = document.querySelector('header nav');
		const header = document.querySelector('header');
		const internal = nav && nav.querySelector('.internal-links');
		if (!toggle || !nav || !internal || !header) return;

		// toggle menu open/close
		toggle.addEventListener('click', function () {
			const open = nav.classList.toggle('menu-open');
			toggle.setAttribute('aria-expanded', String(open));
		});

		// close when clicking outside
		document.addEventListener('click', function (e) {
			if (!nav.classList.contains('menu-open')) return;
			if (!nav.contains(e.target)) {
				nav.classList.remove('menu-open');
				toggle.setAttribute('aria-expanded', 'false');
			}
		}, { passive: true });

		// close on escape
		document.addEventListener('keydown', function (e) {
			if (e.key === 'Escape' && nav.classList.contains('menu-open')) {
				nav.classList.remove('menu-open');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.focus();
			}
		});

		// Auto-set hamburger color to match header text or contrast with header background
		function parseColorString(str) {
			if (!str) return null;
			str = str.trim();
			// hex
			if (str[0] === '#') {
				const hex = str.slice(1);
				if (hex.length === 3) {
					const r = parseInt(hex[0] + hex[0], 16);
					const g = parseInt(hex[1] + hex[1], 16);
					const b = parseInt(hex[2] + hex[2], 16);
					return { r, g, b, a: 1 };
				}
				if (hex.length === 6) {
					const r = parseInt(hex.slice(0, 2), 16);
					const g = parseInt(hex.slice(2, 4), 16);
					const b = parseInt(hex.slice(4, 6), 16);
					return { r, g, b, a: 1 };
				}
			}
			// rgb/rgba
			const m = str.match(/rgba?\(([^)]+)\)/);
			if (m) {
				const parts = m[1].split(',').map(p => p.trim());
				return { r: Number(parts[0]), g: Number(parts[1]), b: Number(parts[2]), a: parts[3] ? Number(parts[3]) : 1 };
			}
			return null;
		}

		function luminance({ r, g, b }) {
			const srgb = [r, g, b].map(v => v / 255).map(v => v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4));
			return 0.2126 * srgb[0] + 0.7152 * srgb[1] + 0.0722 * srgb[2];
		}

		function updateHamburgerColor() {
			const cs = getComputedStyle(header);
			// prefer explicit header text variable
			let headerTextVar = cs.getPropertyValue('--header-text').trim() || null;
			let color = null;
			if (headerTextVar) {
				const parsed = parseColorString(headerTextVar);
				if (parsed) color = `rgb(${parsed.r}, ${parsed.g}, ${parsed.b})`;
			}
			if (!color) {
				// fallback to computed color or background luminance
				const compColor = cs.color || '';
				const parsedColor = parseColorString(compColor);
				if (parsedColor) {
					color = `rgb(${parsedColor.r}, ${parsedColor.g}, ${parsedColor.b})`;
				} else {
					const bg = cs.backgroundColor || '';
					const parsedBg = parseColorString(bg);
					if (parsedBg) {
						const lum = luminance(parsedBg);
						color = lum < 0.5 ? '#ffffff' : '#111827';
					} else {
						color = '#111827';
					}
				}
			}
			header.style.setProperty('--hamburger-color', color);
		}

		updateHamburgerColor();
		const obs = new MutationObserver(() => updateHamburgerColor());
		obs.observe(document.documentElement || document.body, { attributes: true, attributeFilter: ['class', 'style'] });
		window.addEventListener('resize', updateHamburgerColor);

	} catch (err) {
		// noop
	}
})();
</script>
